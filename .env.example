# =============================================================================
# NEXT.js env rules: only variables prefixed with NEXT_PUBLIC_ are exposed to
# the browser (frontend bundle). All other variables are SERVER-ONLY and never
# sent to the client. Do NOT add NEXT_PUBLIC_ to secrets (API keys, service
# role key, SMTP, etc.).
# =============================================================================

# --- Exposed to frontend (required for client-side Supabase auth) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Server-only (never exposed to frontend) ---
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=your_openai_api_key
